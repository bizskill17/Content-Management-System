RewriteEngine On

# Keep real files and folders working normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pretty client-side content routes -> exported static pages
RewriteRule ^course/[^/]+/?$ /course.html [L]
RewriteRule ^lesson/[^/]+/?$ /lesson.html [L]
RewriteRule ^blog/[^/]+/?$ /blog.html [L]
